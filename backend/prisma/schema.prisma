datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  FIELD_WORKER
  MAINTENANCE
}

enum EquipmentStatus {
  AVAILABLE
  RESERVED
  CHECKED_OUT
  OVERDUE
  DUE_SOON_MAINTENANCE
  IN_MAINTENANCE
  OUT_OF_SERVICE
  MAINTENANCE
}

enum RentalStatus {
  PENDING
  APPROVED
  REJECTED
  RESERVED
  CHECKED_OUT
  RETURNED
  OVERDUE
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  DEFERRED
}

enum MaintenanceTrigger {
  ROUTINE
  ISSUE_REPORTED
  INSPECTION
  BREAKDOWN
  ADMIN_REQUEST
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  REVIEWED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NoteTargetType {
  EQUIPMENT_UNIT
  RENTAL
  MAINTENANCE_RECORD
  ISSUE_REPORT
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  REQUEST_SUBMITTED
  REQUEST_APPROVED
  REQUEST_REJECTED
  CHECKED_OUT
  RETURNED
  MAINTENANCE_OPENED
  MAINTENANCE_COMPLETED
  ISSUE_REPORTED
  NOTE_ADDED
}

model User {
  id         String   @id @default(cuid())
  name         String
  email        String   @unique
  role         UserRole
  department   String?
  phoneNumber  String?
  position     String?
  avatarUrl    String?
  isAvatarIcon Boolean  @default(false)
  createdAt    DateTime @default(now())

  submittedRentals  Rental[] @relation("RentalRequester")
  approvedRentals   Rental[] @relation("RentalApprover")
  checkedOutRentals Rental[] @relation("RentalCheckoutBy")
  returnedRentals   Rental[] @relation("RentalReturnBy")

  maintenanceRecords MaintenanceRecord[] @relation("MaintenanceTechnician")
  issueReports       IssueReport[]
  notes              Note[]
  auditLogs          AuditLog[]
}

model Location {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  region      String?
  description String?
  createdAt   DateTime @default(now())

  equipmentUnits EquipmentUnit[]
  rentals        Rental[]
}

model EquipmentCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  code        String  @unique
  description String?

  equipmentTypes EquipmentType[]
}

model EquipmentType {
  id                       String   @id @default(cuid())
  name                     String
  code                     String   @unique
  manufacturer             String?
  model                    String?
  categoryId               String
  description              String?
  defaultMaintenanceDays   Int?
  defaultRentalWarningDays Int?
  requiresApproval         Boolean  @default(false)
  highRisk                 Boolean  @default(false)
  createdAt                DateTime @default(now())

  category EquipmentCategory @relation(fields: [categoryId], references: [id])
  units    EquipmentUnit[]
  rentals  Rental[]

  @@unique([name, model])
}

model EquipmentUnit {
  id                 String          @id @default(cuid())
  assetTag           String          @unique
  serialNumber       String          @unique
  equipmentTypeId    String
  locationId         String
  status             EquipmentStatus @default(AVAILABLE)
  year               Int?
  inServiceDate      DateTime?
  nextMaintenanceDue DateTime?
  lastMaintenanceAt  DateTime?
  notesSummary       String?
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())

  equipmentType EquipmentType @relation(fields: [equipmentTypeId], references: [id])
  location      Location      @relation(fields: [locationId], references: [id])

  rentals            Rental[]
  maintenanceRecords MaintenanceRecord[]
  issueReports       IssueReport[]
  notes              Note[]
  auditLogs          AuditLog[]
}

model Rental {
  id              String       @id @default(cuid())
  equipmentUnitId String?
  equipmentTypeId String
  requesterId     String
  approverId      String?
  checkedOutById  String?
  returnedById    String?
  locationId      String?
  status          RentalStatus @default(PENDING)
  reason          String
  jobSite         String?
  requestedStart  DateTime
  requestedEnd    DateTime
  approvedStart   DateTime?
  approvedEnd     DateTime?
  checkedOutAt    DateTime?
  returnedAt      DateTime?
  rejectedReason  String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  equipmentUnit EquipmentUnit? @relation(fields: [equipmentUnitId], references: [id])
  equipmentType EquipmentType  @relation(fields: [equipmentTypeId], references: [id])
  requester     User           @relation("RentalRequester", fields: [requesterId], references: [id])
  approver      User?          @relation("RentalApprover", fields: [approverId], references: [id])
  checkedOutBy  User?          @relation("RentalCheckoutBy", fields: [checkedOutById], references: [id])
  returnedBy    User?          @relation("RentalReturnBy", fields: [returnedById], references: [id])
  location      Location?      @relation(fields: [locationId], references: [id])

  notes     Note[]
  auditLogs AuditLog[]
}

model MaintenanceRecord {
  id              String             @id @default(cuid())
  equipmentUnitId String
  technicianId    String?
  status          MaintenanceStatus  @default(OPEN)
  trigger         MaintenanceTrigger
  title           String
  description     String?
  scheduledFor    DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  nextDueAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  equipmentUnit EquipmentUnit @relation(fields: [equipmentUnitId], references: [id], onDelete: Cascade)
  technician    User?         @relation("MaintenanceTechnician", fields: [technicianId], references: [id])
  issueReportId String?
  issueReport   IssueReport?  @relation(fields: [issueReportId], references: [id], onDelete: SetNull)

  notes     Note[]
  auditLogs AuditLog[]
}

model IssueReport {
  id              String        @id @default(cuid())
  equipmentUnitId String
  reportedById    String
  title           String
  description     String
  severity        IssueSeverity
  status          IssueStatus   @default(OPEN)
  reportedAt      DateTime      @default(now())
  resolvedAt      DateTime?

  equipmentUnit EquipmentUnit @relation(fields: [equipmentUnitId], references: [id], onDelete: Cascade)
  reportedBy    User          @relation(fields: [reportedById], references: [id])

  maintenanceRecords MaintenanceRecord[]
  notes              Note[]
  auditLogs          AuditLog[]
}

model Note {
  id                  String         @id @default(cuid())
  authorId            String
  body                String
  targetType          NoteTargetType
  equipmentUnitId     String?
  rentalId            String?
  maintenanceRecordId String?
  issueReportId       String?
  createdAt           DateTime       @default(now())

  author            User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  equipmentUnit     EquipmentUnit?     @relation(fields: [equipmentUnitId], references: [id], onDelete: Cascade)
  rental            Rental?            @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  maintenanceRecord MaintenanceRecord? @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)
  issueReport       IssueReport?       @relation(fields: [issueReportId], references: [id], onDelete: Cascade)
  auditLogs         AuditLog[]
}

model AuditLog {
  id                  String      @id @default(cuid())
  action              AuditAction
  actorId             String?
  equipmentUnitId     String?
  rentalId            String?
  maintenanceRecordId String?
  issueReportId       String?
  noteId              String?
  message             String
  createdAt           DateTime    @default(now())

  actor             User?              @relation(fields: [actorId], references: [id], onDelete: SetNull)
  equipmentUnit     EquipmentUnit?     @relation(fields: [equipmentUnitId], references: [id], onDelete: Cascade)
  rental            Rental?            @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  maintenanceRecord MaintenanceRecord? @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)
  issueReport       IssueReport?       @relation(fields: [issueReportId], references: [id], onDelete: Cascade)
  note              Note?              @relation(fields: [noteId], references: [id], onDelete: SetNull)
}
